# 企业微信获客平台 - 生产环境变量配置
# 复制此文件为 .env 并填入真实值

# ================================
# 数据库配置
# ================================
MYSQL_ROOT_PASSWORD=你的 MySQL root 密码
MYSQL_PASSWORD=你的 MySQL 用户密码
REDIS_PASSWORD=你的 Redis 密码

# ================================
# 企业微信配置
# ================================
WECHAT_CORP_ID=你的企业 ID
WECHAT_AGENT_ID=你的应用 ID
WECHAT_SECRET=你的应用 Secret
WECHAT_TOKEN=你的回调 Token
WECHAT_ENCODING_AES_KEY=你的 AES 密钥

# ================================
# 大模型配置
# ================================
DASHSCOPE_API_KEY=你的通义千问 API Key

# ================================
# XXL-Job 配置
# ================================
XXL_JOB_ACCESS_TOKEN=你的 XXL-Job 访问令牌

# ================================
# JWT 配置
# ================================
JWT_SECRET=你的 JWT 密钥（至少 32 位）
